<aside class="sidebar">
  <div class="sidebar-section">
    <nav class="sidebar-nav">
      <a class="sidebar-link <%= activeNav === 'dashboard' ? 'active' : '' %>" href="/dashboard">
        <i data-lucide="layout-dashboard" width="16" height="16"></i>
        Dashboard
      </a>
      <a class="sidebar-link <%= activeNav === 'profile' ? 'active' : '' %>" href="/profile">
        <i data-lucide="user" width="16" height="16"></i>
        Profile
      </a>
    </nav>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-title">Projects &amp; Reviews</div>
    <nav class="sidebar-nav">
      <a class="sidebar-link <%= activeNav === 'projects' ? 'active' : '' %>" href="/projects">
        <i data-lucide="folder-git-2" width="16" height="16"></i>
        My Projects
      </a>
      <a class="sidebar-link <%= activeNav === 'reviews' ? 'active' : '' %>" href="/reviews">
        <i data-lucide="message-square" width="16" height="16"></i>
        Reviews
        <% if (isReviewer) { %>
          <span class="sidebar-badge">3</span>
        <% } %>
      </a>
      <a class="sidebar-link <%= activeNav === 'explore' ? 'active' : '' %>" href="/explore">
        <i data-lucide="compass" width="16" height="16"></i>
        Explore
      </a>
    </nav>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-title">Skills &amp; Certifications</div>
    <nav class="sidebar-nav">
      <a class="sidebar-link <%= activeNav === 'skills' ? 'active' : '' %>" href="/skills">
        <i data-lucide="code-2" width="16" height="16"></i>
        Skills
      </a>
      <a class="sidebar-link <%= activeNav === 'certifications' ? 'active' : '' %>" href="/certifications">
        <i data-lucide="award" width="16" height="16"></i>
        Certifications
      </a>
    </nav>
  </div>

  <% if (isAdmin) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-title">Administration</div>
      <nav class="sidebar-nav">
        <a class="sidebar-link <%= activeNav === 'admin' ? 'active' : '' %>" href="/admin">
          <i data-lucide="shield-check" width="16" height="16"></i>
          Admin Dashboard
        </a>
        <a class="sidebar-link <%= page === 'admin-certifications' ? 'active' : '' %>" href="/admin/certifications">
          <i data-lucide="users" width="16" height="16"></i>
          Certification Requests
          <span class="sidebar-badge">5</span>
        </a>
        <a class="sidebar-link <%= page === 'admin-logs' ? 'active' : '' %>" href="/admin/logs">
          <i data-lucide="file-text" width="16" height="16"></i>
          Activity Logs
        </a>
      </nav>
    </div>
  <% } %>

  <div class="sidebar-divider"></div>

  <div class="sidebar-footer">
    <nav class="sidebar-nav">
      <a class="sidebar-link <%= page === 'profile-edit' ? 'active' : '' %>" href="/profile/edit">
        <i data-lucide="settings" width="16" height="16"></i>
        Settings
      </a>
      <a class="sidebar-link" href="#">
        <i data-lucide="help-circle" width="16" height="16"></i>
        Help &amp; Support
      </a>
    </nav>
  </div>
</aside>