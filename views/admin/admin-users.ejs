<%
const userRows = Array.isArray(users) ? users : [];
const safeRoleStats = roleStats || { total: 0, developers: 0, reviewers:
0, admins: 0, superAdmins: 0 };
%>
<div class="activity-logs-page">
  <div class="page-header">
    <h1>Manage Users</h1>
    <p class="text-secondary">Change roles from the super-admin
      account</p>
    <p class="text-muted">
      <%= safeRoleStats.total %> total ·
      <%= safeRoleStats.developers %> developers ·
      <%= safeRoleStats.reviewers %> reviewers ·
      <%= safeRoleStats.admins %> admins ·
      <%= safeRoleStats.superAdmins %> super-admin
    </p>
  </div>
  <form action="/admin/users" method="get" class="logs-toolbar">
    <div class="search-box">
      <i data-lucide="search" width="18" height="18"
        class="search-icon"></i>
      <input type="text" name="q" value="<%= roleSearchQuery || '' %>"
        placeholder="Search users..." />
    </div>

    <select class="form-select" style="width: auto" name="role">
      <option value="all" <%=(roleFilter || 'all') === 'all' ? 'selected'
        : '' %>>All Roles</option>
      <option value="developer" <%=roleFilter === 'developer' ? 'selected'
        : '' %>>Developer</option>
      <option value="reviewer" <%=roleFilter === 'reviewer' ? 'selected' :
        '' %>>Reviewer</option>
      <option value="admin" <%=roleFilter === 'admin' ? 'selected' : ''
        %>>Admin</option>
    </select>

    <button class="btn btn-secondary" type="submit">
      <i data-lucide="filter" width="16" height="16"></i>
      Apply
    </button>

    <a class="btn btn-secondary" href="/admin/users">
      <i data-lucide="refresh-cw" width="16" height="16"></i>
      Reset
    </a>
  </form>

  <div class="logs-table-wrapper users-roles-table-wrapper">
    <table class="logs-table users-roles-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Email</th>
          <th>Role</th>
          <th>Joined</th>
          <th>Change Role</th>
        </tr>
      </thead>
      <tbody>
        <% userRows.forEach((userItem) => { %>
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:8px;">
              <div class="avatar avatar-sm"><%= (userItem.name ||
                'U').charAt(0) %></div>
              <div>
                <div><strong><%= userItem.name %></strong></div>
                <div class="text-muted">@<%= userItem.username %></div>
                <% if (userItem.isSuperAdmin) { %>
                <span class="badge badge-success">Super Admin</span>
                <% } %>
              </div>
            </div>
          </td>
          <td><%= userItem.email %></td>
          <td>
            <span
              class="badge <%= userItem.role === 'admin' ? 'badge-success' : (userItem.role === 'reviewer' ? 'badge-warning' : 'badge-secondary') %>"><%=
              userItem.role %></span>
          </td>
          <td style="white-space: nowrap"><%= userItem.createdAt ? new
            Date(userItem.createdAt).toLocaleDateString() : 'N/A' %></td>
          <td>
            <% if (userItem.isSuperAdmin) { %>
            <span class="text-muted">Locked</span>
            <% } else { %>
            <form action="/admin/users/<%= userItem._id %>/role"
              method="post"
              style="display:flex;gap:8px;align-items:center;">
              <select class="form-select" name="role"
                style="width:auto; min-width: 130px;">
                <option value="developer" <%=userItem.role === 'developer'
                  ? 'selected' : '' %>>Developer</option>
                <option value="reviewer" <%=userItem.role === 'reviewer' ?
                  'selected' : '' %>>Reviewer</option>
                <option value="admin" <%=userItem.role === 'admin' ?
                  'selected' : '' %>>Admin</option>
              </select>
              <button type="submit" class="btn btn-sm btn-primary">
                <i data-lucide="save" width="14" height="14"></i>
                Save
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
