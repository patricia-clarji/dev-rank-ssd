<div class="activity-logs-page">
  <div class="page-header">
    <h1>Activity Logs</h1>
    <p class="text-secondary">Monitor all platform activity (stored in
      SQLite)</p>
  </div>

  <form action="/admin/logs" method="get" class="logs-toolbar">
    <div class="search-box">
      <i data-lucide="search" width="18" height="18"
        class="search-icon"></i>
      <input type="text" name="q" value="<%= logsSearchQuery || '' %>"
        placeholder="Search logs..." />
    </div>

    <select class="form-select" style="width: auto" name="action">
      <option value>All Actions</option>
      <option value="CREATE_PROJECT" <%=logsActionFilter ===
        'CREATE_PROJECT' ? 'selected' : '' %>>Create Project</option>
      <option value="UPDATE_PROJECT" <%=logsActionFilter ===
        'UPDATE_PROJECT' ? 'selected' : '' %>>Update Project</option>
      <option value="DELETE_PROJECT" <%=logsActionFilter ===
        'DELETE_PROJECT' ? 'selected' : '' %>>Delete Project</option>
      <option value="CREATE_REVIEW" <%=logsActionFilter ===
        'CREATE_REVIEW' ? 'selected' : '' %>>Create Review</option>
      <option value="UPDATE_REVIEW" <%=logsActionFilter ===
        'UPDATE_REVIEW' ? 'selected' : '' %>>Update Review</option>
      <option value="REGISTER_USER" <%=logsActionFilter ===
        'REGISTER_USER' ? 'selected' : '' %>>Register User</option>
    </select>

    <select class="form-select" style="width: auto" name="entity">
      <option value>All Entities</option>
      <option value="User" <%=logsEntityFilter === 'User' ? 'selected' :
        '' %>>User</option>
      <option value="Project" <%=logsEntityFilter === 'Project' ?
        'selected' : '' %>>Project</option>
      <option value="Review" <%=logsEntityFilter === 'Review' ? 'selected'
        : '' %>>Review</option>
      <option value="CertificationRequest" <%=logsEntityFilter ===
        'CertificationRequest' ? 'selected' : '' %>>Certification</option>
    </select>

    <button class="btn btn-secondary" type="submit">
      <i data-lucide="refresh-cw" width="16" height="16"></i>
      Apply
    </button>

    <a class="btn btn-secondary" href="/admin/logs">
      <i data-lucide="download" width="16" height="16"></i>
      Reset
    </a>
  </form>

  <div class="logs-table-wrapper">
    <table class="logs-table">
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>Action</th>
          <th>Entity</th>
          <th>User</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% (activityLogs || []).forEach((logItem) => {
        const actionText = (logItem.action || '').toLowerCase();
        const actionClass = actionText.includes('delete')
        ? 'delete'
        : (actionText.includes('login')
        ? 'login'
        : (actionText.includes('update') ? 'update' : 'create'));
        %>
        <tr>
          <td style="white-space: nowrap"><%= logItem.createdAt %></td>
          <td><span class="log-action-badge <%= actionClass %>"><%=
              logItem.actionLabel || actionClass %></span></td>
          <td><%= logItem.entity %></td>
          <td><%= logItem.actorName || logItem.actor %></td>
          <td><%= logItem.targetLabel || logItem.target %> <%=
            logItem.detailsText ? ('(' + logItem.detailsText + ')') : ''
            %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <button class="pagination-btn" type="button"
      disabled>Previous</button>
    <span class="pagination-info">Page 1 of 1</span>
    <button class="pagination-btn" type="button" disabled>Next</button>
  </div>
</div>
