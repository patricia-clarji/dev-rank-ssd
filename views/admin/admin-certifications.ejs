<div class="admin-certifications-page">
  <div class="page-header">
    <h1>Certification Requests</h1>
    <p class="text-secondary">Review and manage reviewer certification
      applications</p>
  </div>

  <div class="filter-tabs cert-filters">
    <% const certFilters = [
    { value: 'pending', label: 'Pending' },
    { value: 'approved', label: 'Approved' },
    { value: 'rejected', label: 'Rejected' },
    { value: 'all', label: 'All' },
    ]; %>

    <% certFilters.forEach(function (filterOption) {
    const isActive = (statusFilter || 'pending') === filterOption.value;
    const count = (certificationCounts && typeof
    certificationCounts[filterOption.value] === 'number')
    ? certificationCounts[filterOption.value]
    : 0;
    %>
    <a href="/admin/certifications?status=<%= filterOption.value %>"
      class="filter-tab <%= isActive ? 'active' : '' %>">
      <%= filterOption.label %>
      <span class="tab-count"><%= count %></span>
    </a>
    <% }) %>
  </div>

  <% if ((certificationRequests || []).length > 0) { %>
  <% (certificationRequests || []).forEach((requestItem) => { %>
  <div class="cert-request-card">
    <div class="cert-request-header">
      <div class="cert-request-user">
        <div class="avatar"><%= (requestItem.name || 'U').charAt(0)
          %></div>
        <div>
          <a
            href="<%= requestItem.profileUrl || ('/user/' + requestItem.username) %>"><%=
            requestItem.name %></a>
          <div class="text-muted">@<%= requestItem.username %></div>
        </div>
      </div>
      <div class="cert-request-meta">
        <% if (requestItem.status === 'approved') { %>
        <span class="badge badge-success">
          <i data-lucide="check-circle" width="12" height="12"></i>
          Approved
        </span>
        <% } else if (requestItem.status === 'rejected') { %>
        <span class="badge badge-danger">
          <i data-lucide="x-circle" width="12" height="12"></i>
          Rejected
        </span>
        <% } else { %>
        <span class="badge badge-warning">
          <i data-lucide="clock" width="12" height="12"></i>
          Pending
        </span>
        <% } %>
        <span>Applied <%= requestItem.submittedAt %></span>
      </div>
    </div>

    <div class="cert-request-body">
      <div class="cert-request-stats">
        <div class="cert-stat">
          <i data-lucide="folder-git-2" width="18" height="18"
            class="text-accent"></i>
          <div class="cert-stat-value"><%=
            requestItem.applicantProjectsCount || 0 %></div>
          <div class="cert-stat-label">Projects</div>
        </div>
        <div class="cert-stat">
          <i data-lucide="star" width="18" height="18"
            class="text-warning"></i>
          <div class="cert-stat-value"><%=
            Number(requestItem.applicantAvgRating || 0).toFixed(1)
            %></div>
          <div class="cert-stat-label">Avg Rating</div>
        </div>
        <div class="cert-stat">
          <i data-lucide="code" width="18" height="18"
            class="text-success"></i>
          <div class="cert-stat-value"><%=
            requestItem.applicantSkillsCount || 0 %></div>
          <div class="cert-stat-label">Skills</div>
        </div>
        <div class="cert-stat">
          <i data-lucide="briefcase" width="18" height="18"
            class="text-muted"></i>
          <div class="cert-stat-value"><%= requestItem.yearsExperience ||
            'N/A' %></div>
          <div class="cert-stat-label">Years Exp</div>
        </div>
      </div>

      <div class="cert-request-section">
        <h4>Expertise</h4>
        <p><%= requestItem.certificate %></p>
      </div>

      <div class="cert-request-section">
        <h4>Motivation</h4>
        <p><%= requestItem.motivation %></p>
      </div>
    </div>

    <% if (requestItem.status === 'pending') { %>
    <div class="cert-request-actions">
      <form action="/admin/certifications/<%= requestItem._id %>/approve"
        method="post" style="display:inline">
        <button class="btn btn-success" type="submit">
          <i data-lucide="check-circle" width="16" height="16"></i>
          Approve
        </button>
      </form>
      <form action="/admin/certifications/<%= requestItem._id %>/reject"
        method="post" style="display:inline">
        <button class="btn btn-danger" type="submit">
          <i data-lucide="x-circle" width="16" height="16"></i>
          Reject
        </button>
      </form>
      <a
        href="<%= requestItem.profileUrl || ('/user/' + requestItem.username) %>"
        class="btn btn-secondary" style="margin-left: auto">
        <i data-lucide="user" width="16" height="16"></i>
        View Profile
      </a>
    </div>
    <% } %>
  </div>
  <% }) %>
  <% } else { %>
  <div class="empty-state">
    <i data-lucide="award" class="empty-state-icon"></i>
    <h3 class="empty-state-title">No requests</h3>
    <p class="empty-state-description">There are no certification requests
      right now.</p>
  </div>
  <% } %>
</div>
