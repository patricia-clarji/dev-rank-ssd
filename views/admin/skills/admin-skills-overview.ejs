<div class="activity-logs-page">
  <div class="page-header">
    <h1>Manage Skills</h1>
    <p class="text-secondary">Add, edit, and organize platform skills</p>
  </div>

  <form action="/admin/skills" method="get" class="logs-toolbar">
    <div class="search-box">
      <i data-lucide="search" width="18" height="18"
        class="search-icon"></i>
      <input type="text" name="q" value="<%= skillSearchQuery || '' %>"
        placeholder="Search skills..." />
    </div>

    <select class="form-select" style="width: auto" name="category">
      <option value>All Categories</option>
      <option value="frontend" <%=skillCategoryFilter === 'frontend' ?
        'selected' : '' %>>Frontend</option>
      <option value="backend" <%=skillCategoryFilter === 'backend' ?
        'selected' : '' %>>Backend</option>
      <option value="database" <%=skillCategoryFilter === 'database' ?
        'selected' : '' %>>Database</option>
      <option value="devops" <%=skillCategoryFilter === 'devops' ?
        'selected' : '' %>>DevOps</option>
      <option value="mobile" <%=skillCategoryFilter === 'mobile' ?
        'selected' : '' %>>Mobile</option>
      <option value="other" <%=skillCategoryFilter === 'other' ?
        'selected' : '' %>>Other</option>
    </select>

    <button class="btn btn-secondary" type="submit">
      <i data-lucide="refresh-cw" width="16" height="16"></i>
      Apply
    </button>

    <a class="btn btn-secondary" href="/admin/skills">
      <i data-lucide="download" width="16" height="16"></i>
      Reset
    </a>

    <a href="/admin/skills/new" class="btn btn-primary">
      <i data-lucide="plus" width="16" height="16"></i>
      Add New Skill
    </a>
  </form>

  <div class="logs-table-wrapper">
    <table class="logs-table">
      <thead>
        <tr>
          <th>Skill Name</th>
          <th>Category</th>
          <th>Users</th>
          <th>Preset</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% (skills || []).forEach((skill) => { %>
        <tr>
          <td><%= skill.name %></td>
          <td style="text-align: left;">
            <% if (Array.isArray(skill.category)) { %>
            <% skill.category.forEach((cat, index) => { %>
            <span class="badge" style="padding: 0px;"><%= cat %></span><%
            if (index < skill.category.length - 1) { %>,<% } %>
            <% }) %>
            <% } else { %>
            <span class="badge"><%= skill.category || 'General' %></span>
            <% } %>
          </td>
          <td><%= skill.userCount || 0 %></td>
          <td>
            <% if (skill.isPreset) { %>
            <span class="badge badge-success">Yes</span>
            <% } else { %>
            <span class="badge badge-secondary">No</span>
            <% } %>
          </td>
          <td>
            <a href="/admin/skills/<%= skill._id %>/edit"
              class="btn btn-sm btn-secondary">
              <i data-lucide="edit" width="14" height="14"></i>
              Edit
            </a>
            <form action="/admin/skills/<%= skill._id %>/delete"
              method="post" style="display: inline;"
              onsubmit="return confirm('Are you sure you want to delete this skill?')">
              <button type="submit" class="btn btn-sm btn-danger">
                <i data-lucide="trash-2" width="14" height="14"></i>
                Delete
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% if (hasPrevPage) { %>
    <a
      href="?page=<%= currentPage - 1 %>&q=<%= skillSearchQuery %>&category=<%= skillCategoryFilter %>"
      class="pagination-btn">Previous</a>
    <% } else { %>
    <button class="pagination-btn" disabled>Previous</button>
    <% } %>

    <span class="pagination-info">Page <%= currentPage %> of <%=
      totalPages %> (<%= totalSkills %> skills)</span>

    <% if (hasNextPage) { %>
    <a
      href="?page=<%= currentPage + 1 %>&q=<%= skillSearchQuery %>&category=<%= skillCategoryFilter %>"
      class="pagination-btn">Next</a>
    <% } else { %>
    <button class="pagination-btn" disabled>Next</button>
    <% } %>
  </div>
  <% } %>
</div>
