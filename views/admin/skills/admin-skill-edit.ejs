<div class="edit-profile-page">
  <div class="edit-profile-container">
    <div class="page-header">
      <h1>Edit Skill</h1>
      <p class="text-secondary">Update skill information</p>
    </div>

    <form action="/admin/skills/<%= skill._id %>/edit" method="post">
      <div class="form-section">
        <h2>Skill Information</h2>

        <div class="form-group">
          <label class="form-label">Skill Name *</label>
          <input type="text" name="name" class="form-input"
            value="<%= skill.name %>" required />
          <span class="form-hint">The name of the skill (e.g., React,
            Node.js, Python)</span>
        </div>

        <div class="form-group">
          <label class="form-label">Categories</label>
          <div class="category-checkboxes">
            <%
            const skillCategories = (Array.isArray(skill.category) ?
            skill.category : [skill.category])
            .filter(Boolean)
            .flatMap((cat) => String(cat).split(','))
            .map((cat) => cat.trim().toLowerCase())
            .filter(Boolean);
            %>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="frontend"
                  <%=skillCategories.includes('frontend') ? 'checked' : ''
                  %> />
                <span>Frontend</span>
              </label>
            </div>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="backend"
                  <%=skillCategories.includes('backend') ? 'checked' : ''
                  %> />
                <span>Backend</span>
              </label>
            </div>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="database"
                  <%=skillCategories.includes('database') ? 'checked' : ''
                  %> />
                <span>Database</span>
              </label>
            </div>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="devops"
                  <%=skillCategories.includes('devops') ? 'checked' : ''
                  %> />
                <span>DevOps</span>
              </label>
            </div>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="mobile"
                  <%=skillCategories.includes('mobile') ? 'checked' : ''
                  %> />
                <span>Mobile</span>
              </label>
            </div>
            <div class="form-group">
              <label>
                <input type="checkbox" name="category" value="other"
                  <%=skillCategories.includes('other') ? 'checked' : '' %>
                />
                <span>Other</span>
              </label>
            </div>
          </div>
          <span class="form-hint">Select one or more categories for this
            skill</span>
        </div>

        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="isPreset" <%=skill.isPreset ?
              'checked' : '' %> />
            <span>Preset skill (available by default)</span>
          </label>
          <span class="form-hint">Preset skills are available to all users
            without needing to be added manually</span>
        </div>
      </div>

      <div class="form-actions">
        <a href="/admin/skills" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="save" width="16" height="16"></i>
          Save Changes
        </button>
      </div>
    </form>
  </div>
</div>
