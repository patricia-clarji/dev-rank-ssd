<% const isProfileCompletionMode = profileMode === 'complete'; %>
<% const profileFormAction = profileActionPath || '/profile/edit'; %>
<% const profileSubmitText = profileSubmitLabel || 'Save changes'; %>
<% const profileCancelLink = profileCancelPath || '/profile'; %>
<div class="edit-profile-page">
  <div class="edit-profile-container">
    <div class="page-header">
      <h1><%= isProfileCompletionMode ? 'Complete Profile' :
        'Edit Profile' %></h1>
      <p class="text-secondary"><%= isProfileCompletionMode ?
        'Add the details needed to finish setting up your account' :
        'Update your public profile information' %></p>
    </div>

    <form action="<%= profileFormAction %>" method="post">
      <input type="hidden" name="profileMode"
        value="<%= isProfileCompletionMode ? 'complete' : 'edit' %>" />
      <div class="form-section">
        <h2>Basic Information</h2>

        <div class="form-group">
          <label class="form-label">Name</label>
          <input type="text" name="name" class="form-input"
            value="<%= currentUser.name || '' %>"
            <%=isProfileCompletionMode ? 'required' : '' %> />
        </div>

        <div class="form-group">
          <label class="form-label">Bio</label>
          <textarea name="bio" class="form-textarea" rows="4"
            <%=isProfileCompletionMode ? 'required' : ''
            %>><%= currentUser.bio || '' %></textarea>
          <span class="form-hint">Brief description for your profile. Max
            200 characters.</span>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Company</label>
            <input type="text" name="company" class="form-input"
              value="<%= currentUser.company || '' %>" />
          </div>
          <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" name="location" class="form-input"
              value="<%= currentUser.location || '' %>" />
          </div>
        </div>
      </div>

      <div class="form-section">
        <h2>Social Links</h2>

        <div class="form-group">
          <label class="form-label">GitHub</label>
          <input type="url" name="github" class="form-input"
            value="<%= currentUser.github || '' %>"
            placeholder="https://github.com/username"
            <%=isProfileCompletionMode ? 'required' : '' %> />
        </div>

        <div class="form-group">
          <label class="form-label">LinkedIn</label>
          <input type="url" name="linkedin" class="form-input"
            value="<%= currentUser.linkedin || '' %>"
            placeholder="https://linkedin.com/in/username" />
        </div>

        <div class="form-group">
          <label class="form-label">Website</label>
          <input type="url" name="website" class="form-input"
            value="<%= currentUser.website || '' %>"
            placeholder="https://yourwebsite.com" />
        </div>
      </div>

      <div class="form-section">
        <h2>Skills</h2>
        <p class="text-secondary mb-3">Add skills to help others find
          you</p>

        <div class="skills-editor">
          <div class="current-skills" data-skill-chip-group>
            <% normalizedSkills.forEach((skillItem) => { %>
            <span class="skill-tag" data-skill-chip>
              <%= skillItem.name %>
              <button type="button" class="skill-remove" data-skill-remove
                title="Remove skill">
                <i data-lucide="x" width="12" height="12"></i>
              </button>
            </span>
            <% }) %>
            <button type="button" class="btn btn-sm btn-outline"
              data-skill-picker-toggle>
              <i data-lucide="plus" width="14" height="14"></i>
              Add skill
            </button>
          </div>

          <input type="hidden" name="skillsCsv"
            value="<%= normalizedSkills.map((skillItem) => skillItem.name).join(', ') %>"
            data-skill-input />

          <div class="skill-picker hidden" data-skill-picker-panel>
            <div class="skill-picker-header">
              <span>Select a skill</span>
              <button type="button" class="btn btn-link"
                data-skill-picker-close>
                <i data-lucide="x" width="16" height="16"></i>
              </button>
            </div>
            <div class="skill-picker-list">
              <% (skills || []).forEach((skillOption) => { %>
              <button type="button" class="skill-option" data-skill-option
                data-skill-value="<%= skillOption.name %>">
                <span><%= skillOption.name %></span>
                <span class="text-muted text-sm"><%=
                  skillOption.category || 'General' %></span>
              </button>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <% if (!isProfileCompletionMode) { %>
        <a href="<%= profileCancelLink %>"
          class="btn btn-secondary">Cancel</a>
        <% } %>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="save" width="16" height="16"></i>
          <%= profileSubmitText %>
        </button>
      </div>
    </form>
  </div>
</div>
