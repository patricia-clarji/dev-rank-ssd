<%- include('../partials/head', { pageTitle, bodyClass }) %>

<%- include('../partials/toast', { errorMessage, successMessage, warningMessage }) %>

<div class="auth-page">
  <div class="auth-container">
    <div class="auth-intro">
      <p class="auth-eyebrow">Reset your password</p>
      <h1 class="auth-title">Enter new password</h1>
      <p class="auth-subtitle">Choose a strong password for your account.</p>
    </div>

    <div class="auth-card">
      <form action="/reset-password/<%= token %>" method="post" data-password-validation>
        <div class="form-group">
          <label class="form-label">New password</label>
          <div class="password-input">
            <input
              type="password"
              name="password"
              class="form-input"
              required
              autocomplete="new-password"
              placeholder="Minimum 8 characters"
              data-password-field
            />
            <button type="button" class="password-toggle" aria-label="Toggle password visibility">
              <i data-lucide="eye" width="16" height="16"></i>
            </button>
          </div>
          <div class="password-feedback" aria-live="polite">
            <p class="form-hint password-feedback-title">Password requirements</p>
            <ul class="password-requirements-list">
              <li data-password-requirement="minLength">At least 8 characters</li>
              <li data-password-requirement="uppercase">At least 1 uppercase letter</li>
              <li data-password-requirement="lowercase">At least 1 lowercase letter</li>
              <li data-password-requirement="number">At least 1 number</li>
              <li data-password-requirement="special">At least 1 special character</li>
            </ul>
            <p class="form-error password-feedback-error hidden" data-password-feedback-error></p>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Confirm new password</label>
          <input
            type="password"
            name="confirmPassword"
            class="form-input"
            required
            autocomplete="new-password"
            placeholder="Confirm your password"
            data-confirm-password-field
          />
          <p class="form-error password-match-error hidden" data-password-match-error>Passwords do not match.</p>
        </div>

        <button type="submit" class="btn btn-primary btn-block auth-submit">Reset password</button>
      </form>
    </div>

    <div class="auth-card auth-footer-card">
      <p>
        Remember your password?
        <a href="/login">Sign in</a>
      </p>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
