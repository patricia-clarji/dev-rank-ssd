<%- include('../partials/head', { pageTitle, bodyClass }) %>

<div class="auth-page <%= mode === 'register' ? 'auth-page-register' : '' %>">
  <div class="auth-container">
    <a href="/" class="auth-logo">
      <img src="/images/devrank-logo.svg" alt="DevRank" class="auth-logo-mark" />
    </a>

    <div class="auth-intro">
      <p class="auth-eyebrow"><%= mode === 'login' ? 'Welcome back' : 'Join the platform' %></p>
      <h1 class="auth-title"><%= mode === 'login' ? 'Sign in to DevRank' : 'Create your account' %></h1>
      <p class="auth-subtitle"><%= mode === 'login' ? 'Get back to your projects, reviews, and admin tools in one clean step.' : 'Set up a verified developer profile with projects, skills, and peer feedback.' %></p>
    </div>

    <div class="auth-card">
      <form action="/<%= mode === 'login' ? 'login' : 'register' %>" method="post">
        <% if (mode === 'register') { %>
          <div class="form-group">
            <label class="form-label">Username</label>
            <input
              type="text"
              name="username"
              class="form-input"
              required
              autocomplete="username"
              placeholder="johndoe"
            />
            <span class="form-hint">This will be your public profile URL</span>
          </div>

          <div class="form-group">
            <label class="form-label">Email address</label>
            <input
              type="email"
              name="email"
              class="form-input"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </div>

          <div class="form-group">
            <label class="form-label">Full name</label>
            <input
              type="text"
              name="name"
              class="form-input"
              required
              placeholder="John Doe"
            />
          </div>

          <div class="form-group">
            <label class="form-label">Password</label>
            <div class="password-input">
              <input
                type="password"
                name="password"
                class="form-input"
                required
                autocomplete="new-password"
                placeholder="Minimum 8 characters"
              />
              <button type="button" class="password-toggle" aria-label="Toggle password visibility">
                <i data-lucide="eye" width="16" height="16"></i>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Confirm password</label>
            <input
              type="password"
              name="confirmPassword"
              class="form-input"
              required
              autocomplete="new-password"
              placeholder="Confirm your password"
            />
          </div>

          <button type="submit" class="btn btn-primary btn-block auth-submit">Create account</button>

          <p class="auth-terms">
            By creating an account, you agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
          </p>
        <% } else { %>
          <div class="form-group">
            <label class="form-label">Email address</label>
            <input
              type="email"
              name="email"
              class="form-input"
              required
              autocomplete="email"
            />
          </div>

          <div class="form-group">
            <label class="form-label">
              Password
              <a href="#" class="auth-forgot">Forgot password?</a>
            </label>
            <div class="password-input">
              <input
                type="password"
                name="password"
                class="form-input"
                required
                autocomplete="current-password"
              />
              <button type="button" class="password-toggle" aria-label="Toggle password visibility">
                <i data-lucide="eye" width="16" height="16"></i>
              </button>
            </div>
          </div>

          <button type="submit" class="btn btn-primary btn-block auth-submit">Sign in</button>
        <% } %>
      </form>
    </div>

    <div class="auth-card auth-footer-card">
      <p>
        <%= mode === 'login' ? 'New to DevRank?' : 'Already have an account?' %>
        <a href="<%= mode === 'login' ? '/register' : '/login' %>"><%= mode === 'login' ? 'Create an account' : 'Sign in' %></a>
      </p>
    </div>

    <% if (mode === 'login') { %>
      <div class="auth-demo-info">
        <h4>Demo Credentials</h4>
        <div class="demo-accounts">
          <div class="demo-account">
            <span class="badge badge-primary">Developer</span>
            <code>developer@devrank.com / password123</code>
          </div>
          <div class="demo-account">
            <span class="badge badge-success">Reviewer</span>
            <code>reviewer@devrank.com / password123</code>
          </div>
          <div class="demo-account">
            <span class="badge badge-warning">Admin</span>
            <code>admin@devrank.com / admin123</code>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/foot') %>