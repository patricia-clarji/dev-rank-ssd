<div class="project-detail-page">
  <div class="project-detail-header">
    <div class="project-detail-title">
      <i data-lucide="folder-git-2" width="24" height="24"
        class="text-secondary"></i>
      <h1><%= project.title %></h1>
      <% if (project.status === 'reviewed') { %>
      <span class="badge badge-success">
        <i data-lucide="check-circle" width="12" height="12"></i>
        Reviewed
      </span>
      <% } %>
      <% if (project.status === 'seeking-review') { %>
      <span class="badge badge-warning">Seeking Review</span>
      <% } %>
    </div>

    <div class="project-detail-meta">
      <a
        href="/user/<%= projectDetailVM.projectOwner.username || projectDetailVM.projectOwner._id %>">@<%=
        projectDetailVM.projectOwner.username || 'developer' %></a>
      <span>•</span>
      <span>Created <%= project.createdAt ? new
        Date(project.createdAt).toLocaleDateString() : 'N/A' %></span>
    </div>

    <div class="project-detail-actions">
      <% if (project.repoUrl) { %>
      <a href="<%= project.repoUrl %>" target="_blank"
        rel="noopener noreferrer" class="btn btn-secondary">
        <i data-lucide="github" width="16" height="16"></i>
        View Repository
      </a>
      <% } %>

      <% if (project.liveUrl) { %>
      <a href="<%= project.liveUrl %>" target="_blank"
        rel="noopener noreferrer" class="btn btn-secondary">
        <i data-lucide="external-link" width="16" height="16"></i>
        Live Demo
      </a>
      <% } %>

      <% if (isReviewer && !projectDetailVM.isOwner) { %>
      <a href="/projects/<%= project._id %>/review"
        class="btn btn-primary">
        <i data-lucide="message-square" width="16" height="16"></i>
        Write Review
      </a>
      <% } %>

      <% if (projectDetailVM.canModify) { %>
      <a href="/projects/<%= project._id %>/edit"
        class="btn btn-secondary">
        <i data-lucide="edit" width="16" height="16"></i>
        Edit
      </a>
      <form action="/projects/<%= project._id %>/delete" method="post"
        style="display: inline;">
        <button type="submit" class="btn btn-danger"
          onclick="return confirm('Are you sure you want to delete this project? This action cannot be undone.');">
          <i data-lucide="trash-2" width="16" height="16"></i>
          Delete
        </button>
      </form>
      <% } %>
    </div>
  </div>

  <div class="project-detail-content">
    <div class="project-detail-main">
      <div class="project-section">
        <h2>About</h2>
        <p class="project-description"><%= project.description ||
          'No description provided.' %></p>
      </div>

      <div class="project-section">
        <h2>Tech Stack</h2>
        <div class="project-tech-stack">
          <% (project.techStack || []).forEach((tech) => { %>
          <a href="/skills/<%= encodeURIComponent(tech) %>" class="tag"><%= tech %></a>
          <% }) %>
        </div>
      </div>

      <div class="reviews-section">
        <div class="reviews-header">
          <h2>Reviews (<%= projectReviewCards.length %>)</h2>
        </div>

        <% if (projectReviewCards.length > 0) { %>
        <% projectReviewCards.forEach((reviewItem) => { %>
        <div class="review-card">
          <div class="review-card-header">
            <div class="review-author">
              <div class="avatar avatar-sm"><%=
                reviewItem.reviewerInitials || 'U' %></div>
              <div class="review-author-info">
                <span class="review-author-name"><%=
                  reviewItem.reviewerName || ((reviewItem.reviewer &&
                  reviewItem.reviewer.name) || 'Reviewer') %></span>
                <span class="review-date"><%= reviewItem.displayDate ||
                  new Date(reviewItem.createdAt).toLocaleDateString() %> •
                  @<%= reviewItem.reviewerUsername ||
                  ((reviewItem.reviewer && reviewItem.reviewer.username)
                  || 'reviewer') %></span>
              </div>
            </div>
            <div class="review-rating">
              <i data-lucide="star" class="star filled" width="18"
                height="18"></i>
              <%= Number(reviewItem.overallRating || 0).toFixed(1) %>
            </div>
          </div>

          <div class="review-scores">
            <div class="review-score">
              <span class="review-score-label">Code Quality</span>
              <span class="review-score-value"><%=
                Number(reviewItem.codeQuality || 4).toFixed(1) %>/5</span>
            </div>
            <div class="review-score">
              <span class="review-score-label">Creativity</span>
              <span class="review-score-value"><%=
                Number(reviewItem.creativity || 4).toFixed(1) %>/5</span>
            </div>
            <div class="review-score">
              <span class="review-score-label">Clean Code</span>
              <span class="review-score-value"><%=
                Number(reviewItem.cleanCode || 4).toFixed(1) %>/5</span>
            </div>
          </div>

          <p class="review-feedback"><%= reviewItem.feedbackText ||
            reviewItem.feedback || reviewItem.note ||
            'No written feedback provided.' %></p>

          <div class="review-suggestions">
            <h4>Suggestions</h4>
            <ul>
              <% (reviewItem.suggestionsList || reviewItem.suggestions ||
              []).forEach((suggestion) => { %>
              <li><%= suggestion %></li>
              <% }) %>
            </ul>
          </div>

          <div class="review-footer">
            <% if (reviewItem.canEdit) { %>
            <div class="review-actions">
              <a
                href="<%= reviewItem.editUrl || ('/reviews/' + reviewItem._id + '/edit') %>"
                class="review-action-btn">
                <i data-lucide="edit" width="14" height="14"></i>
                Edit
              </a>
              <form
                action="<%= reviewItem.deleteUrl || ('/reviews/' + reviewItem._id + '/delete') %>"
                method="post"
                onsubmit="return confirm('Delete this review?');">
                <input type="hidden" name="returnTo"
                  value="<%= reviewItem.deleteReturnTo || ('/projects/' + (reviewItem.project && reviewItem.project._id ? reviewItem.project._id : '')) %>" />
                <button type="submit" class="review-action-btn danger">
                  <i data-lucide="trash-2" width="14" height="14"></i>
                  Delete
                </button>
              </form>
            </div>
            <% } %>
            <% if (reviewItem.wouldHire) { %>
            <span class="hire-badge positive">
              <i data-lucide="check-circle" width="14" height="14"></i>
              Would Hire
            </span>
            <% } else { %>
            <span class="hire-badge negative">
              <i data-lucide="x-circle" width="14" height="14"></i>
              Would Not Hire
            </span>
            <% } %>
          </div>
        </div>
        <% }) %>
        <% } else { %>
        <div class="empty-state">
          <i data-lucide="message-square" class="empty-state-icon"></i>
          <h3 class="empty-state-title">No reviews yet</h3>
          <% if (projectDetailVM.isOwner) { %>
          <p class="empty-state-description">Your project hasn’t been reviewed yet</p>
          <% } else if (isReviewer && project._id) { %>
          <p class="empty-state-description">Be the first to review this project</p>
          <a href="/projects/<%= project._id %>/review"
            class="btn btn-primary">Write Review</a>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>

    <div class="project-detail-sidebar">
      <div class="sidebar-section">
        <div class="score-display">
          <div class="score-value">
            <i data-lucide="star" class="star filled"></i>
            <%= Number(project.averageRating || 0).toFixed(1) %>
          </div>
          <span class="score-label">Average Rating</span>
        </div>

        <div class="score-breakdown">
          <div class="score-item">
            <span class="score-item-label">Code Quality</span>
            <span class="score-item-value"><%=
              projectDetailVM.codeQuality.toFixed(1) %></span>
          </div>
          <div class="score-item">
            <span class="score-item-label">Creativity</span>
            <span class="score-item-value"><%=
              projectDetailVM.creativity.toFixed(1) %></span>
          </div>
          <div class="score-item">
            <span class="score-item-label">Clean Code</span>
            <span class="score-item-value"><%=
              projectDetailVM.cleanCode.toFixed(1) %></span>
          </div>
        </div>
      </div>

      <div class="sidebar-section">
        <h3>Hire Verdict</h3>
        <div class="hire-stats">
          <i data-lucide="check-circle" width="20" height="20"></i>
          <span><%= reviewStats.wouldHireCount %>/<%=
            projectReviewCards.length %> would hire</span>
        </div>
      </div>

      <div class="sidebar-section">
        <h3>Project Owner</h3>
        <a
          href="/user/<%= projectDetailVM.projectOwner.username || projectDetailVM.projectOwner._id %>"
          class="review-author">
          <div class="avatar avatar-sm"><%=
            (projectDetailVM.projectOwner.name ||
            'U').split(' ').map((part) => part[0]).join('').slice(0,
            2).toUpperCase() %></div>
          <div class="review-author-info">
            <span class="review-author-name"><%=
              projectDetailVM.projectOwner.name || 'Developer' %></span>
            <span class="text-muted">@<%=
              projectDetailVM.projectOwner.username || 'developer'
              %></span>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>
