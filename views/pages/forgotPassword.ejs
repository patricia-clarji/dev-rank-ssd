<%- include('../partials/head', { pageTitle, bodyClass }) %>

<%- include('../partials/toast', { errorMessage, successMessage, warningMessage }) %>

<div class="auth-page">
  <div class="auth-container">
    <div class="auth-intro">
      <p class="auth-eyebrow">Reset your password</p>
      <h1 class="auth-title">Forgot your password?</h1>
      <p class="auth-subtitle">Enter your email address and we'll send you a link to reset your password.</p>
    </div>

    <div class="auth-card">
      <form action="/forgot-password" method="post">
        <div class="form-group">
          <label class="form-label">Email address</label>
          <input
            type="email"
            name="email"
            class="form-input"
            required
            autocomplete="email"
            placeholder="you@example.com"
          />
        </div>

        <button type="submit" class="btn btn-primary btn-block auth-submit">Send reset link</button>
      </form>
    </div>

    <div class="auth-card auth-footer-card">
      <p>
        Remember your password?
        <a href="/login">Sign in</a>
      </p>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>