<%- include('../partials/head', { pageTitle, bodyClass }) %>
<%
/* Controllers MUST supply these view-model variables:
currentUserName, firstName, normalizedSkills,
publicProfileUrl, ownCertification, certStatus, reviewsList,
hireRate, avgProjectRating, certificationRequirements, allRequirementsMet,
certificationRequests, projects, reviews
*/

// Normalize user object (controllers pass 'user', normalize to 'currentUser')
const currentUser = {
...(user || {}),
github: (user && (user.github || user.githubUrl)) || "",
linkedin: (user && (user.linkedin || user.linkedinUrl)) || "",
website: (user && (user.website || user.websiteUrl)) || "",
};

const safeReviews = Array.isArray(reviews) ? reviews : [];
const safeCertifications = Array.isArray(certificationRequests) ?
certificationRequests : [];
const isAdminArea = activeNav === "admin-dashboard" || String(page ||
"").startsWith("admin-");
const sidebarReviewsCount = isAdminArea ? 0 : safeReviews.length;
const sidebarPendingCertificationsCount = safeCertifications.filter((req) =>
String(req.status || "").toLowerCase() === "pending").length;
%>

<div class="layout">
  <%- include('../partials/header', { user: currentUser, isAdmin }) %>

  <div class="layout-body">
    <%- include('../partials/sidebar', {
    activeNav,
    isAdmin,
    isSuperAdmin,
    isReviewer,
    page,
    }) %>

    <main class="layout-main">
      <% if (page === "dashboard") { %>
      <%- include('./dashboard') %>
      <% } else if (page === "profile") { %>
      <%- include('./profile/profile-view') %>
      <% } else if (page === "profile-edit") { %>
      <%- include('./profile/profile-edit') %>
      <% } else if (page === "projects") { %>
      <%- include('./projects/projects-overview') %>
      <% } else if (page === "project-detail") { %>
      <%- include('./projects/project-detail') %>
      <% } else if (page === "project-form") { %>
      <%- include('./projects/project-form') %>
      <% } else if (page === "review-form") { %>
      <%- include('./reviews/review-form') %>
      <% } else if (page === "reviews") { %>
      <%- include('./reviews/reviews-overview') %>
      <% } else if (page === "skills") { %>
      <%- include('./skills/skills-catalog') %>
      <% } else if (page === "skill-detail") { %>
      <%- include('./skills/skill-detail') %>
      <% } else if (page === "certifications") { %>
      <%- include('./certifications/certifications-overview') %>
      <% } else if (page === "certification-apply") { %>
      <%- include('./certifications/certification-apply') %>
      <% } else if (page === "explore") { %>
      <%- include('./explore') %>
      <% } else if (page === "admin-dashboard") { %>
      <%- include('../admin/admin-dashboard') %>
      <% } else if (page === "admin-users") { %>
      <%- include('../admin/admin-users') %>
      <% } else if (page === "admin-certifications") { %>
      <%- include('../admin/admin-certifications') %>
      <% } else if (page === "admin-logs") { %>
      <%- include('../admin/admin-logs') %>
      <% } else if (page === "admin-skills") { %>
      <%- include('../admin/skills/admin-skills-overview') %>
      <% } else if (page === "admin-skill-new") { %>
      <%- include('../admin/skills/admin-skill-new') %>
      <% } else if (page === "admin-skill-edit") { %>
      <%- include('../admin/skills/admin-skill-edit') %>
      <% } %>
    </main>
  </div>
</div>

<%- include('../partials/foot') %>